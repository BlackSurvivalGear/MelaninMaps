rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Role-based helper functions
    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isModerator() {
      return request.auth != null &&
             (exists(/databases/$(database)/documents/moderators/$(request.auth.uid)) || isAdmin());
    }

    // Admin collection rules
    match /admins/{adminId} {
      allow read: if request.auth != null && (request.auth.uid == adminId || isAdmin());
      allow write: if false;
    }

    // Moderator collection rules
    match /moderators/{moderatorId} {
      allow read: if request.auth != null && (request.auth.uid == moderatorId || isAdmin());
      allow write: if isAdmin();
    }

    // User profile rules
    match /users/{userId} {
      allow read: if (request.auth != null && request.auth.uid == userId) || isModerator();
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if (request.auth != null && request.auth.uid == userId &&
                        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['plan', 'subscriptionActivatedAt', 'activatedBy', 'subscriptionExpiry']))
                    || (isAdmin() &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['plan', 'subscriptionActivatedAt', 'activatedBy', 'subscriptionExpiry']));
      allow delete: if isAdmin();
    }

    // Business profile rules (replaces restaurants)
    match /businesses/{uid} {
      // Allow public read access for the map and menu display
      allow read: if true;

      // Allow create if the user is authenticated and matches UID
      allow create: if request.auth != null && request.auth.uid == uid;

      // Allow update if owner OR moderator/admin
      allow update: if (request.auth != null && request.auth.uid == uid &&
                        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['approved', 'featured']))
                    || (isModerator() &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['approved', 'featured']));

      // Allow delete if admin
      allow delete: if isAdmin();
    }

    // Legacy Restaurant profile rules (kept for backward compatibility during migration)
    match /restaurants/{uid} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if isAdmin();
    }

    // Menu Category rules
    match /menuCategories/{categoryId} {
      allow create: if request.auth != null && request.resource.data.restaurantId == request.auth.uid;
      allow read: if (request.auth != null && resource.data.restaurantId == request.auth.uid) || isModerator();
      allow update: if request.auth != null && resource.data.restaurantId == request.auth.uid;
      allow delete: if (request.auth != null && resource.data.restaurantId == request.auth.uid) || isModerator();
    }

    // Menu Item rules
    match /menuItems/{itemId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.restaurantId == request.auth.uid;
      allow update: if request.auth != null && resource.data.restaurantId == request.auth.uid;
      allow delete: if (request.auth != null && resource.data.restaurantId == request.auth.uid) || isModerator();
    }

    // Affiliate rules
    match /affiliates/{uid} {
      // Partner can read their own affiliate document. Admin has full access.
      allow read: if (request.auth != null && request.auth.uid == uid) || isAdmin();

      // Partner can create their own affiliate document.
      allow create: if request.auth != null && request.auth.uid == uid;

      // Partner can update only safe profile fields.
      // Admin has full access to update all fields including earnings.
      // Public increment of totalClicks.
      allow update: if isAdmin()
                    || (request.auth != null && request.auth.uid == uid &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'paypal', 'bankDetails', 'email']))
                    || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalClicks']));
    }

    // Public mapping of referral codes to affiliate UIDs
    match /referralCodes/{code} {
      // Allow public read to lookup affiliate UID from code
      allow read: if true;
      // Only the affiliate owner can create their own code mapping
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow write: if isAdmin();
    }

    // Commission rules
    match /commissions/{commissionId} {
      // Partner can read only commissions belonging to their affiliateId. Admin has full access.
      allow read: if isAdmin() || (request.auth != null && resource.data.affiliateId == request.auth.uid);
      // Commissions should only be created by Admin (Server/Functions) in production.
      allow write: if isAdmin();
    }

    // Referral rules
    match /referrals/{referralId} {
      // Partner can read only referrals belonging to their affiliateId. Admin has full access.
      allow read: if isAdmin() || (request.auth != null && resource.data.affiliateId == request.auth.uid);
      // Create if authenticated (during business registration)
      allow create: if request.auth != null;
      // Admin or business owner update
      allow update: if isAdmin() || (request.auth != null && resource.data.businessId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Order rules
    match /orders/{orderId} {
      allow create: if true;
      allow read: if (request.auth != null && resource.data.restaurantId == request.auth.uid) || isModerator();
      allow update: if (request.auth != null && resource.data.restaurantId == request.auth.uid &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']))
                    || isModerator();
      allow delete: if isAdmin();
    }

    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
